# Copy to `.env` and adjust as needed. docker-compose reads this file
# automatically. The defaults run a fully mocked, key-free stack.

# --- Classification backend -------------------------------------------------
# "mock"  : deterministic rule-based classifier (default, no API key required)
# "ollama": call a real Ollama chat model (local or hosted ollama.com)
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=ollama.
# For the hosted service use https://ollama.com and your API key.
# For a local Ollama daemon use http://host.docker.internal:11434 and no key.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:20b

# --- Worker tuning (optional) ----------------------------------------------
# WORKER_CONCURRENCY=4
# RECONCILE_INTERVAL=15s
# CLAIM_MIN_IDLE=30s
